{
  "name": "glassng",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/liquid-glass-ui/src",
  "prefix": "lib",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": [
        "libs/liquid-glass-ui",
        "{workspaceRoot}/dist/libs/liquid-glass-ui"
      ],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/liquid-glass-ui/ng-package.json",
        "tsConfig": "libs/liquid-glass-ui/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/liquid-glass-ui/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "nx-release-publish": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish dist/libs/liquid-glass-ui --access public --tag {args.tag} --verbose"
      }
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {}
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
